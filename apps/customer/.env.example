# ──────────────────────────────────────────────────────────────
# Doornext Customer App — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Supabase (public — used on client and server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (secret — server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (public — used on client for Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe (secret — server-side only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stream Chat (public — used on client)
NEXT_PUBLIC_STREAM_API_KEY=

# Stream Chat (secret — server-side only)
STREAM_API_SECRET=

# Firebase — Client SDK (public — used in browser for push notifications)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase — Admin SDK (secret — server-side only, used for sending push notifications)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Internal webhook authentication
# Generate with: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET=

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Google Maps (public — used for static map images)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
