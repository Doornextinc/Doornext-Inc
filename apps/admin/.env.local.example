# ============================================================
# Doornext Admin App — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ── Push Notifications ───────────────────────────────────────
# URL of the customer app — used to forward push notifications via the internal FCM endpoint
# Dev: http://localhost:3000 | Prod: https://app.doornext.com
NOTIFY_PUSH_BASE_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=your-internal-webhook-secret

# ── Sentry (optional) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=doornext-admin

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL=info
